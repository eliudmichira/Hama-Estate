{
  "name": "estateui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:prod": "node scripts/clean-production.js && vite build",
    "clean:prod": "node scripts/clean-production.js",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "npm run build:prod && firebase deploy",
    "deploy:full": "node scripts/deploy.js",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "serve": "firebase serve",
    "clean": "rm -rf dist",
    "analyze": "npm run build && npx vite-bundle-analyzer dist"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2",
    "@react-google-maps/api": "^2.20.7",
    "@vis.gl/react-google-maps": "^1.5.4",
    "axios": "^1.4.0",
    "dompurify": "^3.2.6",
    "firebase": "^9.23.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.263.1",
    "maplibre-gl": "^5.6.1",
    "maplibre-react-components": "^0.2.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.45.0",
    "react-leaflet": "^4.2.1",
    "react-map-gl": "^6.1.21",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.14.0",
    "recharts": "^3.1.0",
    "socket.io-client": "^4.8.1",
    "timeago.js": "^4.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.6",
    "sass": "^1.89.2",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "vite": "^5.4.19"
  }
}
